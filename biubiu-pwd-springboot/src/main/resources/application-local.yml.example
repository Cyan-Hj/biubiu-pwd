# 本地开发环境配置模板
# 复制此文件为 application-local.yml 并填写实际配置
# application-local.yml 已被 .gitignore 忽略，不会上传到 Git

spring:
  datasource:
    url: jdbc:mysql://localhost:3306/biubiu_pwd?useUnicode=true&characterEncoding=utf-8&useSSL=false&serverTimezone=Asia/Shanghai
    username: root
    password: 你的数据库密码
    driver-class-name: com.mysql.cj.jdbc.Driver

  jpa:
    hibernate:
      ddl-auto: update
    show-sql: true

jwt:
  secret: 你的JWT密钥（建议32位以上随机字符串）
  expiration: 86400000

file:
  upload:
    path: uploads/

logging:
  level:
    com.biubiu: DEBUG
